        "loader_s_test.go",
        "mocks_test.go",
        "workbook_seeder_s_test.go",
    ],
    deps = [
        ":seed",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//mock",
        "@com_github_stretchr_testify//require",
    ],

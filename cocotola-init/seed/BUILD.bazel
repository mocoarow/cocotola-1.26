load("@rules_go//go:def.bzl", "go_library")
load("//bazel:go_test.bzl", "smart_go_test")

go_library(
    name = "seed",
    srcs = [
        "client.go",
        "doc.go",
        "loader.go",
        "types.go",
        "workbook_seeder.go",
    ],
    embedsrcs = [
        "seeds/public_workbooks.yaml",
